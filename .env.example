# AI_API_KEY: Required for Pear AI API calls.
# ALLHOT_API_KEY: Required for AllHot Open API hot list calls.
# ALLHOT_BACKUP_API_KEY: Optional fallback key when ALLHOT_API_KEY is unavailable.
# Users configure this via GitHub Secrets or local .env file.
AI_API_KEY=MY_PEAR_AI_KEY
ALLHOT_API_KEY=MY_ALLHOT_API_KEY
ALLHOT_BACKUP_API_KEY=MY_ALLHOT_BACKUP_API_KEY
